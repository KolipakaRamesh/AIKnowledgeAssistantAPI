# ── OpenRouter (LLM Provider) ────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Internal API Security ────────────────────────────────────
# This is the 'Front Door' key for your FastAPI server.
# Pass this in the 'X-API-Key' header of your requests.
API_KEY=dev-secret

# ── Vector Store ─────────────────────────────────────────────
CHROMA_PATH=./chroma_db

# ── RAG & LLM Settings ───────────────────────────────────────
LLM_MODEL=openai/gpt-4o-mini
# Cloud-based embeddings (text-embedding-3-small is cheap and fast)
EMBEDDING_MODEL=text-embedding-3-small
# Optional: Dedicated OpenAI key for embeddings. Defaults to OPENROUTER_API_KEY if empty.
OPENAI_API_KEY=
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_GLOBAL=60/minute
RATE_LIMIT_UPLOAD=10/minute

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Observability (Optional) ─────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=AIKnowledgeAssistantAPI
